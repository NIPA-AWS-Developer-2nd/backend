{
  "family": "backend",
  "taskRoleArn": "arn:aws:iam::607735330430:role/halsaram-task-role",
  "executionRoleArn": "arn:aws:iam::607735330430:role/halsaram-task-execution-role",
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "requiresCompatibilities": ["FARGATE"],
  "containerDefinitions": [
    {
      "name": "backend-container",
      "image": "607735330430.dkr.ecr.ap-northeast-2.amazonaws.com/halsaram/backend:latest",
      "cpu": 0,
      "portMappings": [
        {
          "name": "backend-container",
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "restartPolicy": {
        "enabled": true,
        "ignoredExitCodes": []
      },
      "environment": [
        {
          "name": "DB_NAME",
          "value": "halsaram_dev_db"
        },
        {
          "name": "DB_USERNAME",
          "value": "devadmin"
        },
        {
          "name": "DB_HOST",
          "value": "halsaram-aurora-cluster-dev.cluster-ch2mcsuwk0oh.ap-northeast-2.rds.amazonaws.com"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-2:607735330430:secret:rds!cluster-0ea72cf8-019b-43e5-a7fc-7a5b81a1d207-rpxeib:password::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/aws/ecs/backend/backend-container",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
